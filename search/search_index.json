{"config":{"lang":["zh"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u4e92\u8054\u7f51\u7b14\u8bd5\u9762\u8bd5\u77e5\u8bc6\u4f53\u7cfb","text":"<p>\u5206\u5c42\u6574\u7406\u9ad8\u9891\u77e5\u8bc6\u70b9\uff0c\u652f\u6301\u5feb\u901f\u5b9a\u4f4d\u4e0e\u7cfb\u7edf\u590d\u4e60\u3002</p>"},{"location":"#_2","title":"\u77e5\u8bc6\u5bfc\u822a","text":"\u6a21\u5757 \u5185\u5bb9\u6982\u8981 \u8ba1\u7b97\u673a\u7f51\u7edc HTTP/HTTPS\u3001TCP/UDP\u3001IP\u3001\u8def\u7531\u3001ARP \u64cd\u4f5c\u7cfb\u7edf \u8fdb\u7a0b\u7ebf\u7a0b\u3001\u5185\u5b58\u7ba1\u7406\u3001\u5e76\u53d1\u540c\u6b65\u3001IO Linux / Git Linux \u547d\u4ee4\u3001Git \u57fa\u7840\u4e0e\u534f\u4f5c <p>\u4f7f\u7528\u9876\u90e8\u5bfc\u822a\u680f\u6216\u5de6\u4fa7\u83dc\u5355\u5feb\u901f\u8df3\u8f6c\u5404\u7ae0\u8282\uff0c\u652f\u6301\u5168\u6587\u641c\u7d22\u3002</p>"},{"location":"linux-git/","title":"Linux / Git \u547d\u4ee4","text":""},{"location":"linux-git/#linux","title":"Linux \u5e38\u7528\u547d\u4ee4","text":""},{"location":"linux-git/#_1","title":"\u6587\u4ef6\u4e0e\u76ee\u5f55","text":"\u547d\u4ee4 \u8bf4\u660e <code>ls -la</code> \u5217\u51fa\u6240\u6709\u6587\u4ef6\uff08\u542b\u9690\u85cf\uff09\uff0c\u663e\u793a\u8be6\u60c5 <code>cd / pwd</code> \u5207\u6362\u76ee\u5f55 / \u663e\u793a\u5f53\u524d\u8def\u5f84 <code>cp / mv / rm</code> \u590d\u5236 / \u79fb\u52a8 / \u5220\u9664 <code>find . -name \"*.log\"</code> \u9012\u5f52\u641c\u7d22\u6587\u4ef6 <code>grep -rn \"keyword\" .</code> \u9012\u5f52\u641c\u7d22\u5185\u5bb9"},{"location":"linux-git/#_2","title":"\u6743\u9650\u7ba1\u7406","text":"<ul> <li><code>chmod 755 file</code>\uff1a\u8bbe\u7f6e\u6587\u4ef6\u6743\u9650\uff08rwxr-xr-x\uff09</li> <li><code>chown user:group file</code>\uff1a\u4fee\u6539\u6240\u6709\u8005</li> <li><code>sudo</code>\uff1a\u4ee5\u8d85\u7ea7\u7528\u6237\u6743\u9650\u6267\u884c\u547d\u4ee4</li> </ul>"},{"location":"linux-git/#_3","title":"\u8fdb\u7a0b\u4e0e\u7f51\u7edc\u6392\u67e5","text":"\u547d\u4ee4 \u8bf4\u660e <code>ps aux</code> \u67e5\u770b\u6240\u6709\u8fdb\u7a0b <code>top / htop</code> \u5b9e\u65f6\u8fdb\u7a0b\u76d1\u63a7 <code>kill -9 &lt;pid&gt;</code> \u5f3a\u5236\u7ec8\u6b62\u8fdb\u7a0b <code>netstat -antp</code> \u67e5\u770b\u7f51\u7edc\u8fde\u63a5\u4e0e\u7aef\u53e3 <code>ss -tulnp</code> \u67e5\u770b\u76d1\u542c\u7aef\u53e3 <code>curl / wget</code> \u53d1\u8d77 HTTP \u8bf7\u6c42 / \u4e0b\u8f7d\u6587\u4ef6"},{"location":"linux-git/#git","title":"Git \u57fa\u7840","text":"<pre><code>git clone &lt;url&gt;        # \u514b\u9686\u4ed3\u5e93\ngit add .              # \u6682\u5b58\u6240\u6709\u6539\u52a8\ngit commit -m \"msg\"    # \u63d0\u4ea4\ngit log --oneline      # \u7b80\u6d01\u67e5\u770b\u5386\u53f2\ngit diff               # \u67e5\u770b\u672a\u6682\u5b58\u6539\u52a8\n</code></pre>"},{"location":"linux-git/#git_1","title":"Git \u534f\u4f5c","text":"<pre><code>git branch feature     # \u65b0\u5efa\u5206\u652f\ngit checkout feature   # \u5207\u6362\u5206\u652f\ngit merge feature      # \u5408\u5e76\u5206\u652f\u5230\u5f53\u524d\ngit rebase main        # \u53d8\u57fa\u5230 main\ngit stash              # \u4e34\u65f6\u4fdd\u5b58\u5de5\u4f5c\u533a\ngit stash pop          # \u6062\u590d\u6700\u8fd1 stash\n</code></pre>"},{"location":"linux-git/#git_2","title":"Git \u6392\u9519","text":"<pre><code>git reflog             # \u67e5\u770b\u6240\u6709\u64cd\u4f5c\u5386\u53f2\uff08\u627e\u56de\u8bef\u5220\u63d0\u4ea4\uff09\ngit reset --hard HEAD~1  # \u56de\u9000\u5230\u4e0a\u4e00\u4e2a\u63d0\u4ea4\uff08\u5371\u9669\uff1a\u4e22\u5931\u6539\u52a8\uff09\ngit reset --soft HEAD~1  # \u56de\u9000\u63d0\u4ea4\uff0c\u4fdd\u7559\u6539\u52a8\u5230\u6682\u5b58\u533a\ngit cherry-pick &lt;sha&gt;  # \u5c06\u6307\u5b9a\u63d0\u4ea4\u5e94\u7528\u5230\u5f53\u524d\u5206\u652f\ngit revert &lt;sha&gt;       # \u521b\u5efa\u4e00\u4e2a\u53cd\u5411\u63d0\u4ea4\uff08\u5b89\u5168\u64a4\u9500\uff09\n</code></pre>"},{"location":"network/","title":"\u8ba1\u7b97\u673a\u7f51\u7edc","text":""},{"location":"network/#_2","title":"\u5e94\u7528\u5c42","text":"<ul> <li>HTTP / HTTPS\uff1a\u8bf7\u6c42\u65b9\u6cd5\uff08GET/POST/PUT/DELETE\uff09\u3001\u72b6\u6001\u7801\u3001Cookie/Session\u3001HTTPS \u63e1\u624b\u6d41\u7a0b\u3001TLS \u539f\u7406</li> <li>DNS\uff1a\u57df\u540d\u89e3\u6790\u6d41\u7a0b\uff08\u9012\u5f52/\u8fed\u4ee3\uff09\u3001A/CNAME/MX \u8bb0\u5f55\u3001DNS \u7f13\u5b58</li> <li>CDN\uff1a\u5185\u5bb9\u5206\u53d1\u539f\u7406\u3001\u56de\u6e90\u673a\u5236\u3001\u8fb9\u7f18\u8282\u70b9\u7f13\u5b58\u7b56\u7565</li> </ul>"},{"location":"network/#_3","title":"\u4f20\u8f93\u5c42","text":"<ul> <li>TCP \u4e09\u6b21\u63e1\u624b\uff1aSYN \u2192 SYN-ACK \u2192 ACK\uff0c\u4e3a\u4ec0\u4e48\u4e0d\u662f\u4e24\u6b21/\u56db\u6b21</li> <li>TCP \u56db\u6b21\u6325\u624b\uff1aFIN \u2192 ACK \u2192 FIN \u2192 ACK\uff0cTIME_WAIT \u72b6\u6001\u53ca\u610f\u4e49</li> <li>\u6d41\u91cf\u63a7\u5236\uff1a\u6ed1\u52a8\u7a97\u53e3\u673a\u5236</li> <li>\u62e5\u585e\u63a7\u5236\uff1a\u6162\u542f\u52a8\u3001\u62e5\u585e\u907f\u514d\u3001\u5feb\u91cd\u4f20\u3001\u5feb\u6062\u590d</li> <li>UDP\uff1a\u65e0\u8fde\u63a5\u3001\u4e0d\u53ef\u9760\u3001\u4f4e\u5ef6\u8fdf\u573a\u666f\uff08DNS\u3001\u89c6\u9891\u6d41\uff09</li> </ul>"},{"location":"network/#_4","title":"\u7f51\u7edc\u5c42","text":"<ul> <li>IP \u534f\u8bae\uff1aIPv4/IPv6\u3001\u5206\u7247\u4e0e\u91cd\u7ec4</li> <li>\u8def\u7531\uff1a\u9759\u6001\u8def\u7531\u3001\u52a8\u6001\u8def\u7531\uff08OSPF\u3001BGP\uff09</li> <li>NAT\uff1a\u5730\u5740\u8f6c\u6362\u539f\u7406\uff0c\u79c1\u6709\u5730\u5740\u6bb5</li> </ul>"},{"location":"network/#_5","title":"\u94fe\u8def\u5c42","text":"<ul> <li>\u4ee5\u592a\u7f51\uff1a\u5e27\u683c\u5f0f\u3001MTU</li> <li>ARP\uff1aIP \u2192 MAC \u5730\u5740\u89e3\u6790\u6d41\u7a0b\uff0cARP \u7f13\u5b58\uff0cARP \u6b3a\u9a97</li> </ul>"},{"location":"os/","title":"\u64cd\u4f5c\u7cfb\u7edf","text":""},{"location":"os/#_2","title":"\u8fdb\u7a0b\u4e0e\u7ebf\u7a0b","text":"<ul> <li>\u8fdb\u7a0b vs \u7ebf\u7a0b\uff1a\u8d44\u6e90\u9694\u79bb\u3001\u5207\u6362\u5f00\u9500\u3001\u901a\u4fe1\u65b9\u5f0f\uff08\u7ba1\u9053\u3001\u6d88\u606f\u961f\u5217\u3001\u5171\u4eab\u5185\u5b58\uff09</li> <li>\u8fdb\u7a0b\u72b6\u6001\uff1a\u5c31\u7eea \u2192 \u8fd0\u884c \u2192 \u963b\u585e \u2192 \u5c31\u7eea\uff08\u4e94\u6001\u6a21\u578b\uff09</li> <li>\u8c03\u5ea6\u7b56\u7565\uff1aFCFS\u3001SJF\u3001\u4f18\u5148\u7ea7\u8c03\u5ea6\u3001\u65f6\u95f4\u7247\u8f6e\u8f6c\u3001\u591a\u7ea7\u53cd\u9988\u961f\u5217</li> </ul>"},{"location":"os/#_3","title":"\u5185\u5b58\u7ba1\u7406","text":"<ul> <li>\u5206\u9875\uff1a\u9875\u8868\u3001TLB \u52a0\u901f\u3001\u9875\u9762\u7f6e\u6362\u7b97\u6cd5\uff08LRU\u3001LFU\u3001Clock\uff09</li> <li>\u5206\u6bb5\uff1a\u903b\u8f91\u5206\u6bb5\u4e0e\u7269\u7406\u6620\u5c04</li> <li>\u865a\u62df\u5185\u5b58\uff1a\u7f3a\u9875\u4e2d\u65ad\u3001demand paging\u3001swap \u4ea4\u6362\u5206\u533a</li> </ul>"},{"location":"os/#_4","title":"\u5e76\u53d1\u4e0e\u540c\u6b65","text":"<ul> <li>\u4e92\u65a5\u9501 / \u81ea\u65cb\u9501\uff1a\u9002\u7528\u573a\u666f\u4e0e\u5f00\u9500\u5bf9\u6bd4</li> <li>\u4fe1\u53f7\u91cf\uff1aP/V \u64cd\u4f5c\uff0c\u7528\u4e8e\u8d44\u6e90\u8ba1\u6570\u4e0e\u540c\u6b65</li> <li>\u6b7b\u9501\uff1a\u56db\u4e2a\u5fc5\u8981\u6761\u4ef6\uff08\u4e92\u65a5\u3001\u5360\u6709\u7b49\u5f85\u3001\u4e0d\u5265\u593a\u3001\u5faa\u73af\u7b49\u5f85\uff09\u3001\u9884\u9632/\u907f\u514d/\u68c0\u6d4b/\u89e3\u9664</li> <li>\u6761\u4ef6\u53d8\u91cf\uff1a\u4e0e\u4e92\u65a5\u9501\u914d\u5408\u4f7f\u7528</li> </ul>"},{"location":"os/#io","title":"IO \u4e0e\u6587\u4ef6\u7cfb\u7edf","text":"<ul> <li>IO \u6a21\u578b\uff1a\u963b\u585e\u3001\u975e\u963b\u585e\u3001IO \u591a\u8def\u590d\u7528\uff08select/poll/epoll\uff09\u3001\u5f02\u6b65 IO</li> <li>epoll\uff1a\u8fb9\u7f18\u89e6\u53d1\uff08ET\uff09vs \u6c34\u5e73\u89e6\u53d1\uff08LT\uff09\uff0c\u9ad8\u5e76\u53d1\u5b9e\u73b0\u539f\u7406</li> <li>\u6587\u4ef6\u7cfb\u7edf\uff1ainode \u7ed3\u6784\u3001\u8f6f\u94fe\u63a5 vs \u786c\u94fe\u63a5\u3001\u7f13\u51b2\u533a\u7f13\u5b58</li> </ul>"}]}